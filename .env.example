# =============================================================================
# Delego — Environment Configuration
# Copy to .env and adjust values for local development.
# =============================================================================

# --- General ---
NODE_ENV=development
LOG_LEVEL=debug

# --- API Gateway ---
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3001,http://localhost:3002

# --- Frontend Apps ---
WEB_PORT=3001
MERCHANT_PORT=3002
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- Services (internal) ---
ORCHESTRATOR_URL=http://localhost:3010
AGENTS_URL=http://localhost:3011
WALLET_URL=http://localhost:3012
CATALOG_URL=http://localhost:3013
PAYMENTS_URL=http://localhost:3014
NOTIFICATIONS_URL=http://localhost:3015
ANALYTICS_URL=http://localhost:3016

# --- PostgreSQL ---
DATABASE_URL=postgresql://delego:delego@localhost:5432/delego
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Stellar / Soroban ---
# STELLAR_NETWORK selects the public network: testnet | mainnet | futurenet.
# Defaults to "testnet" when unset.
STELLAR_NETWORK=testnet

# Optional: explicit Horizon override. If unset, the default URL for the
# configured STELLAR_NETWORK is used.
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Optional: explicit Soroban RPC override. If unset, the default URL for the
# configured STELLAR_NETWORK is used.
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Optional: explicit Stellar network passphrase. Must match STELLAR_NETWORK
# (one of Test SDF Network ; September 2015 / Public Global Stellar Network ;
# September 2015 / Test SDF Future Network ; October 2022) or — together with
# explicit STELLAR_HORIZON_URL and SOROBAN_RPC_URL — be a custom value for
# standalone test networks. Set, but blank/whitespace, values are rejected.
# STELLAR_PASSPHRASE=Test SDF Network ; September 2015

# Contract IDs (deploy and fill after local deployment)
ESCROW_CONTRACT_ID=
REPUTATION_CONTRACT_ID=
PERMISSIONS_CONTRACT_ID=
MARKETPLACE_CONTRACT_ID=

# Wallet service (never commit real secrets)
WALLET_MASTER_SECRET=
WALLET_SIGNER_SECRET=

# --- AI Agents ---
# TODO: Configure provider keys when implementing agent runtime
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Notifications ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
PUSH_PROVIDER_KEY=

# --- Auth (placeholder) ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- Analytics ---
ANALYTICS_ENABLED=true
